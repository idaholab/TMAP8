[Tests]
  design = 'TrappingNodalKernel.md ReleasingNodalKernel.md MatNeumannBC.md'
  issues = '#399'
  validation = 'val-2k.md'
  [val-2k_csvdiff]
    type = CSVDiff
    input = val-2k.i
    csvdiff = val-2k_out.csv
    heavy = true
    requirement = 'The system shall be able to model the natural-oxide baseline of validation case val-2k using deuterium diffusion, trapping, and D2 surface recombination in self-damaged tungsten.'
  []
  [val-2k_exodiff]
    type = Exodiff
    input = val-2k.i
    exodiff = val-2k_out.e
    prereq = val-2k_csvdiff
    should_execute = false
    heavy = true
    requirement = 'The system shall be able to produce the full field solution for the natural-oxide baseline of validation case val-2k.'
  []
  [val-2k_comparison]
    type = RunCommand
    command = 'python3 comparison_val-2k.py'
    requirement = 'The system shall be able to generate comparison plots for the staged val-2k validation workflow as additional experimental datasets are connected to the model.'
    required_python_packages = 'matplotlib numpy pandas os'
  []
[]
