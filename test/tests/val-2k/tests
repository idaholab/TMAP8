[Tests]
  design = 'SpeciesTrappingPhysics.md MatNeumannBC.md'
  issues = '#399'
  validation = 'val-2k.md'
  [val-2k_implicit_euler_csvdiff]
    type = CSVDiff
    input = val-2k.i
    cli_args = 'Executioner/scheme=implicit-euler
                Outputs/file_base=val-2k_implicit_euler_out'
    csvdiff = val-2k_implicit_euler_out.csv
    heavy = true
    requirement = 'The system shall be able to model deuterium transport in self-irradiated tungsten with a natural oxide layer during a TDS experiment using deuterium diffusion, trapping, and D2 surface recombination, using the implicit Euler time integration scheme.'
  []
  [val-2k_implicit_euler_exodiff]
    type = Exodiff
    input = val-2k.i
    exodiff = val-2k_implicit_euler_out.e
    prereq = val-2k_implicit_euler_csvdiff
    should_execute = false
    heavy = true
    requirement = 'The system shall be able to produce the full field solution of a simulation of deuterium transport in self-irradiated tungsten with a natural oxide layer during a TDS experiment using deuterium diffusion, trapping, and D2 surface recombination, using the implicit Euler time integration scheme.'
  []
  [val-2k_bdf2_csvdiff]
    type = CSVDiff
    input = val-2k.i
    cli_args = 'Outputs/file_base=val-2k_out'
    csvdiff = val-2k_out.csv
    heavy = true
    requirement = 'The system shall be able to model deuterium transport in self-irradiated tungsten with a natural oxide layer during a TDS experiment using deuterium diffusion, trapping, and D2 surface recombination, using the backwards differencing formula of second order (BDF-2) time integration scheme.'
  []
  [val-2k_bdf2_initial_profile_csvdiff]
    type = CSVDiff
    input = val-2k.i
    csvdiff = val-2k_profile_initial_out_line_profile_0000.csv
    prereq = val-2k_bdf2_csvdiff
    should_execute = false # this test relies on the output files from val-2k_bdf2_csvdiff, so it shouldn't be run twice
    heavy = true
    requirement = 'The system shall be able to output the initial deuterium concentration profile for the val-2k natural-oxide baseline, including the mobile and trapped populations used to initialize the desorption calculation.'
  []
  [val-2k_comparison]
    type = RunCommand
    command = 'python3 comparison_val-2k.py'
    requirement = 'The system shall be able to generate comparison plots for the val-2k validation, comparing the tungsten-only and 5 nm oxide-layer deuterium-release cases against the experimental data.'
    required_python_packages = 'matplotlib numpy pandas os'
  []
  [val-2k_5nm_oxide_bdf2_csvdiff]
    type = CSVDiff
    input = val-2k_5nm_oxide.i
    csvdiff = val-2k_5nm_oxide_out.csv
    heavy = true
    requirement = 'The system shall be able to model deuterium transport in self-irradiated tungsten with an explicit 5 nm oxide layer during a TDS experiment using deuterium diffusion, trapping, and D2 surface recombination, using the backwards differencing formula of second order (BDF-2) time integration scheme.'
  []
  [val-2k_5nm_oxide_exodiff]
    type = Exodiff
    input = val-2k_5nm_oxide.i
    exodiff = val-2k_5nm_oxide_out.e
    prereq = val-2k_5nm_oxide_bdf2_csvdiff
    should_execute = false
    heavy = true
    requirement = 'The system shall be able to produce the full field solution of a simulation of deuterium transport in self-irradiated tungsten with an explicit 5 nm oxide layer during a TDS experiment using deuterium diffusion, trapping, and D2 surface recombination.'
  []
  [val-2k_5nm_oxide_initial_profile_csvdiff]
    type = CSVDiff
    input = val-2k_5nm_oxide.i
    csvdiff = val-2k_5nm_oxide_profile_initial_out_line_profile_0000.csv
    prereq = val-2k_5nm_oxide_bdf2_csvdiff
    should_execute = false
    heavy = true
    requirement = 'The system shall be able to output the initial deuterium concentration profile for the explicit 5 nm oxide companion case in val-2k, including the mobile and trapped populations used to initialize the desorption calculation.'
  []
[]
