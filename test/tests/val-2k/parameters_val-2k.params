# This file configures the natural-oxide oxygen-field variant of val-2k.
# Unit system:
# - length: micrometers in the input file
# - time: seconds
# - concentration: atoms / micrometer^3
# - flux: atoms / micrometer^2 / second

oxide_thickness = '${units 1 nm -> mum}'
# output_file_base = 'val-2k_out'
profile_output_file_base = 'val-2k_profile_initial_out'

!include parameters_val-2k_oxygen_field_common.params
