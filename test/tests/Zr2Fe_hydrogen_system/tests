  [Zr2FeHx_PCT_error_low_pressure]
    type = RunException
    input = Zr2FeHx_PCT.i
    cli_args = 'initial_pressure_H2_enclosure_1=1'
    expect_err = 'In Zr2FeHxPCT: pressure'
    requirement = 'The system shall be able to return a warning when the pressure and temperature are outside the range of validity of the Zr2FeHxPCT model (pressure too low).'
  []
  [Zr2FeHx_PCT_error_high_pressure]
    type = RunException
    input = Zr2FeHx_PCT.i
