[Tests]
  design = 'InterfaceDiffusion.md ADMatInterfaceReactionZr2FeHxPCT.md MatDiffusion.md TimeDerivative.md'
  issues = '#364'
  [Zr2FeHx_PCT_csv]
    type = CSVDiff
    input = Zr2FeHx_PCT.i
    csvdiff = Zr2FeHx_PCT_out.csv
    requirement = 'The system shall be able to model the PCT curves of Zr2FeHx to determine the surface atomic fraction as a function of pressure and temperature.'
  []
  [Zr2FeHx_PCT_exodus]
    type = Exodiff
    input = Zr2FeHx_PCT.i
    exodiff = Zr2FeHx_PCT_out.e
    prereq = Zr2FeHx_PCT_csv
    should_execute = false # this test relies on the output files from Zr2FeHx_PCT_csv, so it shouldn't be run twice
    requirement = 'The system shall be able to model the PCT curves of Zr2FeHx to determine the surface atomic fraction as a function of pressure and temperature and generate an exodus file.'
  []
  [Zr2FeHx_PCT_T598_P1e03_csv]
    type = CSVDiff
    input = Zr2FeHx_PCT.i
    cli_args = "output_file_base=Zr2FeHx_PCT_T598_P1e03_out
                ${dt_init}=1e1
                temperature=598.15
                initial_pressure_H2_enclosure_1=1e3
                initial_atomic_fraction=3.0
                Executioner/num_steps=150
                Functions/function_BC_concentration_H_enclosure_1/expression=' exp(-${dt_init}*2e-2/t)* ${initial_concentration_H_enclosure_1}'"
    csvdiff = Zr2FeHx_PCT_T598_P1e03_out.csv
    requirement = 'The system shall be able to model the PCT curves of Zr2FeHx to determine the surface atomic fraction as a function of pressure and temperature for P=1e3 Pa and T=598.15 K.'

  []
